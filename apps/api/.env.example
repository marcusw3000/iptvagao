NODE_ENV=development
PORT=3001

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/iptvagao"

JWT_SECRET="change-me-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"

REDIS_URL="redis://localhost:6379"

# Multiple origins: comma-separated (web admin + TV app)
WEB_URL="http://localhost:3000,http://localhost:3002"

# AbacatePay
ABACATEPAY_API_KEY="abacate_live_..."
ABACATEPAY_WEBHOOK_SECRET="your-webhook-secret"
ABACATEPAY_API_URL="https://api.abacatepay.com/v2"

# Supabase Storage (channel logo uploads) — Settings > API in the Supabase dashboard
SUPABASE_URL="https://xxxxxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
SUPABASE_STORAGE_BUCKET="channel-logos"

# GitHub Releases (hospedagem do APK do app Android TV) — repo público, sem limite de tamanho
# Token fine-grained com permissão "Contents: Read and write" só nesse repo
GITHUB_TOKEN="github_pat_..."
GITHUB_REPO="marcusw3000/iptvagao"

# EPG (guia de programação) — URL do guide.xml gerado pelo serviço epg-grabber (docker-compose)
# Sem essa variável, o import agendado fica inativo (endpoint manual POST /epg/import continua funcionando)
EPG_SOURCE_URL="http://epg-grabber:3000/guide.xml"
EPG_IMPORT_CRON="0 6 * * *"
